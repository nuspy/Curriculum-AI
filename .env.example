# AutoJob — esempio di configurazione (copiare in .env). Tutte le var hanno prefisso AUTOJOB_.

# Daemon
AUTOJOB_HOST=127.0.0.1
AUTOJOB_PORT=8765
AUTOJOB_LOG_LEVEL=INFO

# Storage (default: <repo>/data/autojob.db)
# AUTOJOB_DB_PATH=E:/Projects/AutoJob/data/autojob.db
# AUTOJOB_DATA_DIR=E:/Projects/AutoJob/data

# Embeddings (modello locale multilingue via endpoint OpenAI-compatible)
AUTOJOB_EMBED_DIM=1024
AUTOJOB_EMBED_MODEL=bge-m3
AUTOJOB_EMBED_BASE_URL=http://127.0.0.1:1234/v1
# AUTOJOB_EMBED_API_KEY=lm-studio

# Generazione (provider locale di default: lm_studio | ollama | agent)
AUTOJOB_LLM_PROVIDER=lm_studio
AUTOJOB_LLM_BASE_URL=http://127.0.0.1:1234/v1
AUTOJOB_LLM_MODEL=
# AUTOJOB_LLM_API_KEY=lm-studio

# Browser driver MVP: cdp_mcp | claude_chrome | extension | fake
AUTOJOB_BROWSER_DRIVER=fake

# Comportamento candidature
AUTOJOB_SUBMIT_MODE=manual          # manual | semi | auto
AUTOJOB_REAPPLY_POLICY=warn         # block | warn | allow

# Lifecycle: autostart LM Studio + spegnimento per inattività
AUTOJOB_LMS_AUTOSTART=true
AUTOJOB_LMS_CLI=lms
AUTOJOB_LMS_MODEL=                   # modello chat da caricare (fallback: AUTOJOB_LLM_MODEL)
AUTOJOB_IDLE_SHUTDOWN_ENABLED=true
AUTOJOB_IDLE_SHUTDOWN_MINUTES=30
